{
  "name": "passport-oauth-mcp",
  "version": "1.0.0",
  "description": "MCP OAuth 2.1 implementation using Passport.js",
  "main": "oauth-server/server.js",
  "type": "module",
  "scripts": {
    "start": "node oauth-server/server.js",
    "start:https": "ENABLE_HTTPS=true node oauth-server/server.js",
    "mcp": "node mcp-server/server.js",
    "mcp-oauth": "node mcp-server-oauth/server.js",
    "mcp-oauth:https": "ENABLE_HTTPS=true node mcp-server-oauth/server.js",
    "simple": "node simple-mcp-server.js",
    "claude": "node claude-connector/stdio-server.js",
    "web": "node web-client/server.js",
    "test": "node test/oauth-flow-test.js",
    "test:mcp": "node test/mcp-integration-test.js",
    "dev": "concurrently \"npm run start\" \"npm run mcp\" \"npm run web\"",
    "dev-oauth": "concurrently \"npm run start\" \"npm run mcp-oauth\"",
    "dev-oauth-https": "concurrently \"npm run start:https\" \"npm run mcp-oauth\"",
    "dev-mcp-https": "concurrently \"npm run start\" \"npm run mcp-oauth:https\"",
    "dev-full-https": "concurrently \"npm run start\" \"npm run mcp-oauth:https\"",
    "dev-full": "concurrently \"npm run start\" \"npm run mcp\" \"npm run web\" \"sleep 3 && open http://localhost:8847\"",
    "install-deps": "npm install"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "cors": "^2.8.5",
    "cross-fetch": "^4.0.0",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "eventsource": "^2.0.2",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "oauth",
    "mcp",
    "passport",
    "claude",
    "authentication"
  ],
  "author": "Remote MCP Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
