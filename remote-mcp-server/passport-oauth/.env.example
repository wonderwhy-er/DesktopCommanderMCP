# OAuth Server Configuration
OAUTH_PORT=4449
OAUTH_HTTPS_PORT=4450
OAUTH_HOST=localhost
OAUTH_BASE_URL=http://localhost:4449

# Enable HTTPS support (requires certs/server.crt and certs/server.key)
ENABLE_HTTPS=false

# MCP Server Configuration  
MCP_OAUTH_PORT=3005              # HTTP port
MCP_OAUTH_HTTPS_PORT=3006        # HTTPS port (for Claude Desktop)  
MCP_OAUTH_HOST=localhost
MCP_OAUTH_BASE_URL=http://localhost:3005   # Auto-detects HTTPS when enabled

# Session and Security
SESSION_SECRET=your-session-secret-change-in-production-make-it-long-and-random
JWT_SECRET=your-jwt-secret-change-in-production-make-it-long-and-random
DEMO_MODE=true

# Client Defaults
DEFAULT_CLIENT_ID=mcp-client
DEFAULT_CLIENT_SECRET=mcp-secret-change-in-production
DEFAULT_REDIRECT_URI=http://localhost:8847/callback
DEFAULT_SCOPES=openid email profile mcp:tools

# Remote Integration
REMOTE_SERVER_URL=http://localhost:3002
REMOTE_SERVER_ENDPOINT=/api/mcp/execute

# Demo Users (for development)
DEMO_USER_EMAIL=test@example.com
DEMO_USER_PASSWORD=password123
DEMO_USER_NAME=Demo User

# Token Configuration
ACCESS_TOKEN_EXPIRY=3600
REFRESH_TOKEN_EXPIRY=86400
AUTHORIZATION_CODE_EXPIRY=600

# PKCE Configuration
PKCE_REQUIRED=true
SUPPORTED_CODE_CHALLENGE_METHODS=S256

# Logging
LOG_LEVEL=info
DEBUG_MODE=false