# Remote MCP Server Configuration

# Database Configuration
# Use your existing PostgreSQL database
POSTGRES_URL="postgresql://username@localhost:5432/your_database"

# Server Configuration  
PORT=3003
NODE_ENV=development

# JWT Secret (for fallback authentication)
JWT_SECRET="your-secret-key-change-in-production-make-it-long-and-random"

# OAuth Configuration - Ory Integration
# These URLs point to the Docker containers started by docker-compose.oauth.yml
HYDRA_ADMIN_URL="http://localhost:4445"
HYDRA_PUBLIC_URL="http://localhost:4444"
KRATOS_ADMIN_URL="http://localhost:4434"
KRATOS_PUBLIC_URL="http://localhost:4433"

# OAuth Client Configuration for Remote MCP
OAUTH_CLIENT_ID="remote-mcp-client"
OAUTH_CLIENT_SECRET="remote-mcp-secret-change-in-production"
OAUTH_REDIRECT_URI="http://localhost:3003/auth/callback"
OAUTH_SCOPES="openid email profile"

# Development Notes:
# - For OAuth mode: Use PORT=3003 (default above)
# - For JWT mode: Use PORT=3002 (to avoid conflicts)
# - Update POSTGRES_URL to match your database
# - Change all secrets for production use