# Supabase MCP Server Configuration
# Copy this file to .env and update with your values

# ==========================================
# CORE SERVER CONFIGURATION
# ==========================================

# MCP Server URL - Use tunnel URL for Claude Desktop integration
# Development: http://localhost:3007
# Production: https://your-tunnel-domain.trycloudflare.com
MCP_SERVER_URL=http://localhost:3007

# Server binding (change to 0.0.0.0 for external access)
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=3007

# Environment
NODE_ENV=development

# ==========================================
# SUPABASE CONFIGURATION
# ==========================================

# Get these from your Supabase project dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==========================================
# SECURITY CONFIGURATION
# ==========================================

# Generate random strings for production
SESSION_SECRET=your-session-secret-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production

# Debug mode (set to false in production)
DEBUG_MODE=true

# ==========================================
# OAUTH CONFIGURATION (Auto-derived)
# ==========================================

# These are automatically derived from MCP_SERVER_URL:
# OAUTH_REDIRECT_URL=${MCP_SERVER_URL}/auth/callback
# CORS_ORIGINS=["${MCP_SERVER_URL}"]

# ==========================================
# REMOVED LEGACY SETTINGS
# ==========================================

# The following settings are NO LONGER NEEDED:
# WEB_SERVER_PORT=3008          ❌ Removed - Web integrated into MCP server
# WEB_APP_URL=http://localhost:3008  ❌ Removed - Use MCP_SERVER_URL
# OAUTH_REDIRECT_URL=http://localhost:3008/auth/callback  ❌ Auto-derived
# CORS_ORIGINS=["http://localhost:3008", "http://localhost:3002"]  ❌ Auto-derived

# ==========================================
# CLOUDFLARE TUNNEL EXAMPLE
# ==========================================

# For production deployment with Cloudflare tunnel:
# MCP_SERVER_URL=https://found-federation-lenders-consistency.trycloudflare.com
# MCP_SERVER_HOST=0.0.0.0
# NODE_ENV=production
# DEBUG_MODE=false